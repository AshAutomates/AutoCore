# Ignore test screenshots
tests/

# Ignore Python packaging metadata
autocore.egg-info/

# Ignore Python cache
__pycache__/
*.pyc
*.pyo

# Ignore Sphinx build output
docs/build/

# Ignore virtual environments
venv/
.venv/
env/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore PyCharm IDE settings
.idea/

# Build output - generated by python -m build, will get uploaded to PyPI via GitHub Actions
dist/

# Temporary build files - generated during package build process
build/

# Package metadata - auto-generated by setuptools, not needed in version control
*.egg-info/

# This is post install flag file created by __init__.py after first import.
# This is added to prevent no message display if this was accidently present due to push.
autocore/.install_shown